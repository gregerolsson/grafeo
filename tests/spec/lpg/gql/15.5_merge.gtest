# GQL MERGE clause: ISO/IEC 39075:2024 sec 15.5
#
# MERGE matches existing elements or creates new ones.
# Covers: basic merge, composite keys, UNWIND interaction,
# ON CREATE SET, ON MATCH SET.

meta:
  language: gql
  model: lpg
  section: "15.5"
  title: MERGE clause
  dataset: empty
  iso: [GD01]

tests:

  # ---------------------------------------------------------------------------
  # Basic MERGE
  # ---------------------------------------------------------------------------

  - name: merge_creates_when_not_exists
    statements:
      - "MERGE (:City {name: 'Amsterdam'})"
      - "MATCH (c:City) RETURN c.name"
    expect:
      rows:
        - [Amsterdam]

  - name: merge_does_not_duplicate
    statements:
      - "MERGE (:City {name: 'Amsterdam'})"
      - "MERGE (:City {name: 'Amsterdam'})"
      - "MATCH (c:City) RETURN count(c) AS cnt"
    expect:
      rows:
        - [1]

  - name: merge_different_values_create_multiple
    statements:
      - "MERGE (:City {name: 'Amsterdam'})"
      - "MERGE (:City {name: 'Berlin'})"
      - "MATCH (c:City) RETURN count(c) AS cnt"
    expect:
      rows:
        - [2]

  # ---------------------------------------------------------------------------
  # Composite keys
  # ---------------------------------------------------------------------------

  - name: merge_composite_key_no_duplicate
    statements:
      - "MERGE (:City {name: 'Amsterdam', country: 'NL'})"
      - "MERGE (:City {name: 'Amsterdam', country: 'NL'})"
      - "MATCH (c:City) RETURN count(c) AS cnt"
    expect:
      rows:
        - [1]

  - name: merge_composite_key_partial_match_creates_new
    # Same name, different country: should create a second node
    statements:
      - "MERGE (:City {name: 'Amsterdam', country: 'NL'})"
      - "MERGE (:City {name: 'Amsterdam', country: 'US'})"
      - "MATCH (c:City) RETURN count(c) AS cnt"
    expect:
      rows:
        - [2]

  - name: merge_three_property_key
    statements:
      - "MERGE (:Place {city: 'Berlin', country: 'DE', district: 'Mitte'})"
      - "MERGE (:Place {city: 'Berlin', country: 'DE', district: 'Mitte'})"
      - "MERGE (:Place {city: 'Berlin', country: 'DE', district: 'Kreuzberg'})"
      - "MATCH (p:Place) RETURN count(p) AS cnt"
    expect:
      rows:
        - [2]

  # ---------------------------------------------------------------------------
  # MERGE with UNWIND
  # ---------------------------------------------------------------------------

  - name: unwind_merge_returns_one_row_per_input
    # GrafeoDB/grafeo#185
    # MERGE in a loop must return one row per UNWIND input,
    # even when the node already exists after the first iteration.
    query: UNWIND [1, 1, 1] AS i MERGE (:Item {val: i}) RETURN i
    expect:
      count: 3

  - name: unwind_merge_creates_single_node
    statements:
      - "UNWIND [1, 1, 1] AS i MERGE (:Item {val: i})"
      - "MATCH (n:Item) RETURN count(n) AS cnt"
    expect:
      rows:
        - [1]

  - name: unwind_merge_distinct_creates_multiple
    statements:
      - "UNWIND [1, 2, 3] AS i MERGE (:Item {val: i})"
      - "MATCH (n:Item) RETURN count(n) AS cnt"
    expect:
      rows:
        - [3]

  - name: unwind_merge_mixed_create_and_match
    setup:
      - "INSERT (:Item {val: 2})"
    statements:
      - "UNWIND [1, 2, 3] AS i MERGE (:Item {val: i})"
      - "MATCH (n:Item) RETURN count(n) AS cnt"
    expect:
      rows:
        - [3]

  # ---------------------------------------------------------------------------
  # ON CREATE SET / ON MATCH SET
  # ---------------------------------------------------------------------------

  - name: merge_on_create_set
    statements:
      - "MERGE (n:Item {val: 1}) ON CREATE SET n.status = 'new'"
      - "MATCH (n:Item) RETURN n.val, n.status"
    expect:
      rows:
        - [1, new]

  - name: merge_on_match_set
    setup:
      - "INSERT (:Item {val: 1, status: 'old'})"
    statements:
      - "MERGE (n:Item {val: 1}) ON MATCH SET n.status = 'updated'"
      - "MATCH (n:Item) RETURN n.val, n.status"
    expect:
      rows:
        - [1, updated]

  - name: merge_on_create_and_on_match
    setup:
      - "INSERT (:Item {val: 1, status: 'old'})"
    statements:
      - "UNWIND [1, 2] AS i MERGE (n:Item {val: i}) ON CREATE SET n.status = 'new' ON MATCH SET n.status = 'updated'"
      - "MATCH (n:Item) RETURN n.val, n.status ORDER BY n.val"
    expect:
      ordered: true
      rows:
        - [1, updated]
        - [2, new]

  # ---------------------------------------------------------------------------
  # ON CREATE / ON MATCH SET that reference the MERGE variable.
  # GrafeoDB/grafeo#317. ISO/IEC 39075:2024 §15.5: the variable bound by the
  # MERGE pattern is in scope inside ON CREATE / ON MATCH SET, so expressions
  # like `coalesce(c.description, 'fallback')` must evaluate against the
  # merged node, not error with `Undefined variable 'c'`.
  # ---------------------------------------------------------------------------

  - name: merge_on_create_set_self_reference_default
    # Reduced repro from issue #317: ON CREATE coalesces over a property that
    # is absent on the freshly-created node, so the fallback branch wins.
    statements:
      - "MERGE (c:Category {name: 'Electronics'}) ON CREATE SET c.description = coalesce(c.description, 'Consumer electronics')"
      - "MATCH (c:Category {name: 'Electronics'}) RETURN c.description"
    expect:
      rows:
        - [Consumer electronics]

  - name: merge_on_match_set_self_reference_preserves_existing
    # Issue #317 follow-up: rerunning MERGE on an existing node with a
    # coalesce-over-self ON MATCH must keep the prior description.
    setup:
      - "INSERT (:Category {name: 'Electronics', description: 'Consumer electronics'})"
    statements:
      - "MERGE (c:Category {name: 'Electronics'}) ON CREATE SET c.description = 'unexpected' ON MATCH SET c.description = coalesce(c.description, 'fallback')"
      - "MATCH (c:Category {name: 'Electronics'}) RETURN c.description"
    expect:
      rows:
        - [Consumer electronics]

  - name: merge_on_match_set_self_reference_falls_back_when_null
    # ON MATCH coalesce(c.description, 'fallback') must fall back when the
    # matched node has no description property.
    setup:
      - "INSERT (:Category {name: 'Books'})"
    statements:
      - "MERGE (c:Category {name: 'Books'}) ON MATCH SET c.description = coalesce(c.description, 'Books and reading')"
      - "MATCH (c:Category {name: 'Books'}) RETURN c.description"
    expect:
      rows:
        - [Books and reading]

  - name: merge_on_create_self_reference_arithmetic
    # Reach for a non-coalesce expression to exercise the runtime evaluator.
    statements:
      - "MERGE (n:Item {val: 19}) ON CREATE SET n.score = (n.val + 81) * 3"
      - "MATCH (n:Item {val: 19}) RETURN n.score"
    expect:
      rows:
        - [300]

  - name: merge_on_match_increment_self_property
    # Counter pattern: ON CREATE seeds, ON MATCH increments a self-reference.
    statements:
      - "MERGE (n:Counter {id: 1}) ON CREATE SET n.cnt = 1 ON MATCH SET n.cnt = n.cnt + 1"
      - "MERGE (n:Counter {id: 1}) ON CREATE SET n.cnt = 1 ON MATCH SET n.cnt = n.cnt + 1"
      - "MERGE (n:Counter {id: 1}) ON CREATE SET n.cnt = 1 ON MATCH SET n.cnt = n.cnt + 1"
      - "MATCH (n:Counter {id: 1}) RETURN n.cnt"
    expect:
      rows:
        - [3]
